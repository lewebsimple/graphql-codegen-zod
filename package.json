{
  "name": "@lewebsimple/graphql-codegen-zod",
  "version": "0.1.4",
  "description": "GraphQL Codegen preset for generating Zod schemas.",
  "homepage": "https://github.com/lewebsimple/graphql-codegen-zod#readme",
  "bugs": {
    "url": "https://github.com/lewebsimple/graphql-codegen-zod/issues"
  },
  "license": "AGPL-3.0-only",
  "author": "Pascal Martineau <pascal@lewebsimple.ca>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lewebsimple/graphql-codegen-zod.git"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/preset.d.ts",
      "default": "./dist/preset.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rolldown --config ./rolldown.config.ts && tsc",
    "codegen": "graphql-codegen",
    "format": "oxfmt .",
    "lint": "oxlint . --fix",
    "prepare": "husky",
    "release": "pnpm lint && pnpm test && pnpm build && changelogen --release --push && pnpm publish",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/plugin-helpers": "^6.1.1",
    "@graphql-codegen/typed-document-node": "^6.1.7",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "es-toolkit": "^1.45.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.3",
    "@types/node": "^25.4.0",
    "changelogen": "^0.6.2",
    "graphql": "^16.13.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "rolldown": "1.0.0-rc.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "graphql": "^16.13.1",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,json,md}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "changelog": {
    "noAuthors": true,
    "types": {
      "chore": false
    }
  }
}
